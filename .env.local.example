# Copy this file to .env.local and fill in real values.
# .env.local is gitignored and must never be committed.

# Supabase — Project Settings > API in your Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key bypasses Row Level Security. Only ever used in
# server-only code (never in a client component, never NEXT_PUBLIC_).
SUPABASE_SERVICE_ROLE_KEY=

# Stripe — Developers > API keys in your Stripe dashboard (test mode)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Twilio — for SMS notifications
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Resend — for transactional email
RESEND_API_KEY=
